# 本地开发环境配置
# 复制此文件为 .env 并填入实际值
#
# 注意：此文件用于本地开发，与根目录 .env (Docker 部署) 是分开的
# 本地开发时数据库运行在宿主机，所以 DB_HOST 为 localhost

# 数据库 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=nova_space

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# 服务端口
PORT=3001

# 前端地址
FRONTEND_URL=http://localhost:5173

# 环境
NODE_ENV=development

# ESA DISCOS API (用于获取卫星质量、尺寸等扩展信息)
# 申请地址: https://discosweb.esoc.esa.int
ESA_DISCOS_API_TOKEN=your_esa_discos_api_token_here

# SMTP 邮件配置 (用于推送订阅)
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=wwp.personal@qq.com
SMTP_PASS=lullksiujacvbdfh
SMTP_FROM=noreply@nova-space.com